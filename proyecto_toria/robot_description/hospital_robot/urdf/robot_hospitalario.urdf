<?xml version="1.0"?>
<robot name="hospital_logistics_robot">

  <!-- ==================== MATERIALES ==================== -->
  <material name="White">
    <color rgba="0.95 0.95 0.97 1.0"/>
  </material>
  <material name="BlueMedical">
    <color rgba="0.0 0.45 0.75 1.0"/>
  </material>
  <material name="DarkMetal">
    <color rgba="0.15 0.15 0.18 1.0"/>
  </material>
  <material name="BlackRubber">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="LightGrey">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="Screen">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="LED_Green">
    <color rgba="0.0 1.0 0.2 1.0"/>
  </material>

  <!-- ==================== BASE FOOTPRINT ==================== -->
  <link name="base_footprint"/>

  <!-- ==================== CHASIS BASE (Cilíndrico estilizado) ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.25" length="0.25"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="White"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.25" length="0.25"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="25.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.8"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CUERPO CENTRAL (TORSO) ==================== -->
  <link name="torso">
    <visual>
      <geometry>
        <box size="0.3 0.35 0.8"/>
      </geometry>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <material name="White"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.35 0.8"/>
      </geometry>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <inertia ixx="0.6" ixy="0" ixz="0" iyy="0.6" iyz="0" izz="0.2"/>
    </inertial>
  </link>

  <joint name="torso_joint" type="fixed">
    <parent link="base_link"/>
    <child link="torso"/>
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
  </joint>

  <!-- ==================== COMPARTIMENTO DE CARGA (Acento azul) ==================== -->
  <link name="cargo_box">
    <visual>
      <geometry>
        <box size="0.32 0.37 0.5"/>
      </geometry>
      <origin xyz="0.02 0 0.3" rpy="0 0 0"/>
      <material name="BlueMedical"/>
    </visual>
  </link>

  <joint name="cargo_joint" type="fixed">
    <parent link="torso"/>
    <child link="cargo_box"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CABEZA / PANTALLA ==================== -->
  <link name="head">
    <visual>
      <geometry>
        <box size="0.05 0.3 0.2"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0.4 0"/>
      <material name="DarkMetal"/>
    </visual>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="torso"/>
    <child link="head"/>
    <origin xyz="0.12 0 0.85" rpy="0 0 0"/>
  </joint>

  <link name="screen">
    <visual>
      <geometry>
        <box size="0.01 0.26 0.16"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0.4 0"/>
      <material name="Screen"/>
    </visual>
  </link>

  <joint name="screen_joint" type="fixed">
    <parent link="head"/>
    <child link="screen"/>
    <origin xyz="0.021 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== SENSOR LIDAR (En la parte superior) ==================== -->
  <link name="lidar">
    <visual>
      <geometry>
        <cylinder radius="0.06" length="0.06"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="DarkMetal"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.06" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="torso"/>
    <child link="lidar"/>
    <origin xyz="0 0 0.83" rpy="0 0 0"/>
  </joint>

  <!-- ==================== RUEDAS ==================== -->
  <!-- Rueda derecha -->
  <link name="wheel_right">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="BlackRubber"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="0 -0.22 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rueda izquierda -->
  <link name="wheel_left">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="BlackRubber"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <origin xyz="0 0.22 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RUEDAS LOCAS -->
  <link name="caster_front">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="LightGrey"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
  </link>
  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front"/>
    <origin xyz="0.18 0 -0.1" rpy="0 0 0"/>
  </joint>

  <link name="caster_rear">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="LightGrey"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
  </link>
  <joint name="caster_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_rear"/>
    <origin xyz="-0.18 0 -0.1" rpy="0 0 0"/>
  </joint>

  <!-- ==================== GAZEBO PLUGINS ==================== -->
  <gazebo reference="base_link">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="torso">
    <material>Gazebo/White</material>
  </gazebo>
  <gazebo reference="cargo_box">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="screen">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <updateRate>50</updateRate>
      <leftJoint>wheel_left_joint</leftJoint>
      <rightJoint>wheel_right_joint</rightJoint>
      <wheelSeparation>0.44</wheelSeparation>
      <wheelDiameter>0.2</wheelDiameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>
  </gazebo>

  <gazebo reference="lidar">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>40</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>